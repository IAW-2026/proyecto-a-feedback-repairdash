// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

model Usuario {
  id                     Int         @id 
  mail                   String      @unique
  nombre                 String
  apellido               String
  valoracion             Int
  tipo                   TipoUsuario
  trabajosComoCliente    Trabajo[]   @relation("TrabajoCliente") //Esto son nombres a las relaciones
  trabajosComoTrabajador Trabajo[]   @relation("TrabajoTrabajador")
  reviews                Review[]
  reportesHechos         Reporte[]   @relation("ReporteReportante")
  reportesRecibidos      Reporte[]   @relation("ReporteReportado")
  //Un usuario tiene N trabajos dependiendo de lo que haga y cada trabajo tiene un cliente
  /**
   * /**
   * /**
   * /**
   * /*CONSULTAR
   * Como hago esto? lo dejo como usuario o lo vuelvo a separar. Si lo separo, como hago
   * para diferenciar las reviews unificadas y la conexion entre trabajador y cliente
   */
}

enum TipoUsuario {
  Cliente
  Trabajador
}

model Trabajo {
  id            Int      @id 
  idCliente     Int
  idTrabajador  Int
  tipoDeTrabajo String
  fechaInicio   DateTime
  fechaFin      DateTime?
  cliente       Usuario  @relation("TrabajoCliente", fields: [idCliente], references: [id])
  trabajador    Usuario  @relation("TrabajoTrabajador", fields: [idTrabajador], references: [id])
  reviews       Review[]
  reporte       Reporte?
  /**
   * Logica de mi app, despues pido que sea obligatorio.
   * lo dejo en opcional en la base de datos
   */
}

model Review {
  id         Int     @id @default(autoincrement())
  idTrabajo  Int
  idUsuario  Int
  valoracion Int?
  review     String?
  autor      Usuario @relation(fields: [idUsuario], references: [id])
  trabajo    Trabajo @relation(fields: [idTrabajo], references: [id])
  @@unique([idTrabajo, idUsuario])
}

//Preguntar si esto esta bien.
model Reporte {
  id          Int       @id @default(autoincrement())
  idTrabajo   Int       @unique
  idReportado Int
  idReportante Int
  decision    Fallo?
  pruebas     Pruebas[]
  resolucion  Estado    @default(SinResolver)
  trabajo     Trabajo   @relation(fields: [idTrabajo], references: [id])
  reportado   Usuario   @relation("ReporteReportado", fields: [idReportado], references: [id])
  reportante  Usuario   @relation("ReporteReportante", fields: [idReportante], references: [id])

}
enum Fallo{
  AFavor
  EnContra
}

model Pruebas {
  id        Int     @id @default(autoincrement())
  idReporte Int
  tipo      String
  url       String
  reporte   Reporte @relation(fields: [idReporte], references: [id])
}

enum Estado {
  SinResolver
  Resuelto
}
